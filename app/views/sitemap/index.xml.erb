<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <!-- Homepage -->
  <url>
    <loc>https://www.maldivesbeachvacation.com/</loc>
    <lastmod><%= Date.current.iso8601 %></lastmod>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- Static Pages -->
  <url>
    <loc>https://www.maldivesbeachvacation.com/about</loc>
    <lastmod><%= Date.current.iso8601 %></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc>https://www.maldivesbeachvacation.com/contact</loc>
    <lastmod><%= Date.current.iso8601 %></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>

  <url>
    <loc>https://www.maldivesbeachvacation.com/offers</loc>
    <lastmod><%= Date.current.iso8601 %></lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>

  <!-- Properties Index -->
  <url>
    <loc>https://www.maldivesbeachvacation.com/properties</loc>
    <lastmod><%= Date.current.iso8601 %></lastmod>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- Individual Properties -->
  <% @properties.each do |property| %>
  <url>
    <loc>https://www.maldivesbeachvacation.com/properties/<%= property.id %></loc>
    <lastmod><%= property.updated_at.iso8601 %></lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  <% end %>

  <!-- Stories Index -->
  <url>
    <loc>https://www.maldivesbeachvacation.com/stories</loc>
    <lastmod><%= Date.current.iso8601 %></lastmod>
    <changefreq>daily</changefreq>
    <priority>0.7</priority>
  </url>

  <!-- Individual Stories -->
  <% @stories.each do |story| %>
  <url>
    <loc>https://www.maldivesbeachvacation.com/stories/<%= story.id %></loc>
    <lastmod><%= story.updated_at.iso8601 %></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  <% end %>
</urlset>
