<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
    <h1 style="color: #2c3e50;">New Booking Received</h1>

    <p style="font-size: 16px; line-height: 1.5;">
        A new booking has been received for <%= @property.name %>.
    </p>

    <div style="background: #f8f9fa; padding: 20px; border-radius: 5px; margin: 20px 0; border-left: 4px solid #007bff;">
        <h2 style="color: #2c3e50; margin-top: 0;">Booking Details</h2>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
            <div>
                <p style="margin: 5px 0;"><strong>Booking Reference:</strong><br><%= @booking.token %></p>
                <p style="margin: 5px 0;"><strong>Full Name:</strong><br><%= @booking.full_name %></p>
                <p style="margin: 5px 0;"><strong>Email:</strong><br><%= @booking.email %></p>
                <p style="margin: 5px 0;"><strong>Phone:</strong><br><%= @booking.phone_number %></p>
            </div>
            <div>
                <p style="margin: 5px 0;"><strong>Check-in Date:</strong><br><%= @booking.check_in.strftime("%B %d, %Y") %></p>
                <p style="margin: 5px 0;"><strong>Check-out Date:</strong><br><%= @booking.check_out.strftime("%B %d, %Y") %></p>
                <p style="margin: 5px 0;"><strong>Room Type:</strong><br><%= @booking.room_type %></p>
                <p style="margin: 5px 0;"><strong>Number of Rooms:</strong><br><%= @booking.rooms %></p>
            </div>
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
            <div>
                <p style="margin: 5px 0;"><strong>Meal Plan:</strong><br><%= @booking.meal_plan %></p>
                <p style="margin: 5px 0;"><strong>Number of Guests:</strong><br><%= @booking.adults %> adults, <%= @booking.children %> children</p>
            </div>
            <div>
                <% if @booking.additional_service_request.present? %>
                <p style="margin: 5px 0;"><strong>Additional Requests:</strong><br><%= @booking.additional_service_request %></p>
                <% end %>
            </div>
        </div>
    </div>

    <div style="background: #e8f4f8; padding: 15px; border-radius: 5px; margin: 20px 0;">
        <h3 style="color: #2c3e50; margin-top: 0;">Property Details</h3>
        <p style="margin: 5px 0;"><strong>Property Name:</strong> <%= @property.name %></p>
        <p style="margin: 5px 0;"><strong>Address:</strong> <%= @property.address %></p>
        <p style="margin: 5px 0;"><strong>Tagline:</strong> <%= @property.tagline %></p>
    </div>

    <p style="font-size: 16px; line-height: 1.5; margin-top: 30px;">
        Please follow up with the customer to confirm their booking.
    </p>

    <div style="border-top: 1px solid #eee; padding-top: 20px; margin-top: 30px;">
        <p style="color: #666; font-size: 14px; margin: 0;">
            This email was automatically generated from the Maldives Beach Vacation booking system.
        </p>
    </div>
</div>
